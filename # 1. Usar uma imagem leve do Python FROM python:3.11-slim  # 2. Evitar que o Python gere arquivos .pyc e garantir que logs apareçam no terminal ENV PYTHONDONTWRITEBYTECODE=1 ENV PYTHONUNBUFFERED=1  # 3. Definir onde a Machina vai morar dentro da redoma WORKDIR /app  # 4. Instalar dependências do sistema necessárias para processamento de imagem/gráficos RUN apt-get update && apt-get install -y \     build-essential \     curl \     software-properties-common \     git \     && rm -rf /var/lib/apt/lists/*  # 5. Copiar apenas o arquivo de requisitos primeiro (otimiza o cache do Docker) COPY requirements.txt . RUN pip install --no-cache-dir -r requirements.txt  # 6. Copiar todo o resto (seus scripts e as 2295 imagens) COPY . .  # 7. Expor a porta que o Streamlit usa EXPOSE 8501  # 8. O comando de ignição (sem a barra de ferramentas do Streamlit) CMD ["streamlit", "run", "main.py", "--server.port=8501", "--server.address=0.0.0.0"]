# 1. Usar uma imagem leve do Python
FROM python:3.11-slim

# 2. Evitar que o Python gere arquivos .pyc e garantir que logs apareçam no terminal
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# 3. Definir onde a Machina vai morar dentro da redoma
WORKDIR /app

# 4. Instalar dependências do sistema necessárias para processamento de imagem/gráficos
RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    software-properties-common \
    git \
    && rm -rf /var/lib/apt/lists/*

# 5. Copiar apenas o arquivo de requisitos primeiro (otimiza o cache do Docker)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 6. Copiar todo o resto (seus scripts e as 2295 imagens)
COPY . .

# 7. Expor a porta que o Streamlit usa
EXPOSE 8501

# 8. O comando de ignição (sem a barra de ferramentas do Streamlit)
CMD ["streamlit", "run", "main.py", "--server.port=8501", "--server.address=0.0.0.0"]
